@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pending Approval</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/successpage.css" rel="stylesheet">
   
</head>
<body class="d-flex align-items-center justify-content-center">

    <div class="container content">
        <div class="row justify-content-center">

            <div class="col-md-6 col-lg-5">

                <div class="card shadow-lg border-0 status-card text-center">

                    <div class="card-body p-5">

                        <!-- Icon -->
                        <div class="mb-3">
                            <i class="bi bi-hourglass-split status-icon"></i>
                        </div>

                        <!-- Title -->
                        <h4 class="fw-bold">Profile Submitted</h4>

                        <!-- Message -->
                        <p class="text-muted mt-3">
                            Your profile has been successfully submitted and is currently under review.
                        </p>

                        <p class="text-muted">
                            Please wait for HR approval before accessing system features.
                        </p>

                        <!-- Status Badge -->
                        <span class="badge bg-warning text-dark px-3 py-2 mt-2">
                            Pending HR Approval
                        </span>

                        <!-- Optional Note -->
                        <div class="mt-4">
                            <small class="text-muted">
                                You will be notified once your account has been approved.
                            </small>
                        </div>

                        <!-- Back / Logout -->
                        <div class="mt-4">
                            <a href="/Account/Login" class="btn btn-outline-light">
                                Back to Login
                            </a>
                        </div>

                    </div>
                </div>

                <!-- Footer -->
                <div class="text-center text-white mt-3 small">
                    © @DateTime.Now.Year OJT System
                </div>

            </div>

        </div>
    </div>

</body>
</html>