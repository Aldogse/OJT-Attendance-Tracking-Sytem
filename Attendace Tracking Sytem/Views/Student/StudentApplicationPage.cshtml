
@model Attendace_Tracking_Sytem.DTO.StudentApplicationDTO

<!DOCTYPE html>

<html lang="en">

<head>

    ```
    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>
        Student Applications
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">


</head>

<body class="bg-light">


    <div class="container py-5">

        <div class="row justify-content-center">

            <div class="col-md-8">

                <div class="card shadow-sm">

                    <div class="card-header">

                        <h3 class="mb-0">
                            Student Applicant Form
                        </h3>

                    </div>

                    <div class="card-body">

                        <form method="post"
                              asp-action="StudentApplicationPage"
                              asp-controller="Student"
                              enctype="multipart/form-data">

                            <div class="mb-3">

                                <label asp-for="FullName"
                                       class="form-label">
                                </label>

                                <input asp-for="FullName"
                                       class="form-control"
                                       type="text">

                                <span asp-validation-for="FullName"
                                      class="text-danger">
                                </span>

                            </div>

                            <div class="mb-3">

                                <label asp-for="School"
                                       class="form-label">
                                </label>

                                <input asp-for="School"
                                       class="form-control"
                                       type="text">

                                <span asp-validation-for="School"
                                      class="text-danger">
                                </span>

                            </div>

                            <div class="mb-3">

                                <label asp-for="Course"
                                       class="form-label">
                                </label>

                                <input asp-for="Course"
                                       class="form-control"
                                       type="text">

                                <span asp-validation-for="Course"
                                      class="text-danger">
                                </span>

                            </div>

                            <div class="mb-3">

                                <label asp-for="Year"
                                       class="form-label">
                                </label>

                                <input asp-for="Year"
                                       class="form-control"
                                       type="number">

                                <span asp-validation-for="Year"
                                      class="text-danger">
                                </span>

                            </div>

                            <div class="mb-3">

                                <label asp-for="Description"
                                       class="form-label">
                                </label>

                                <textarea asp-for="Description"
                                          class="form-control"
                                          rows="5">
                            </textarea>

                                <span asp-validation-for="Description"
                                      class="text-danger">
                                </span>

                            </div>

                            <div class="mb-4">

                                <label asp-for="Resume"
                                       class="form-label">
                                </label>

                                <input asp-for="Resume"
                                       class="form-control"
                                       type="file"
                                       accept=".pdf,.doc,.docx">

                                <span asp-validation-for="Resume"
                                      class="text-danger">
                                </span>

                            </div>

                            <button type="submit"
                                    class="btn btn-primary w-100">

                                Submit Application

                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>
