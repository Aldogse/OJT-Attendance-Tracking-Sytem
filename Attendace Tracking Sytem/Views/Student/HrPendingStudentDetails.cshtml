@model Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentPendingWorkProfileVM


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Details</title>

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container py-5">      
        <!-- Page Header -->
        <div class="mb-4">
            <h2 class="fw-bold">Student Details</h2>
            <p class="text-muted mb-0">Review and manage student internship information</p>
        </div>

        <!-- Student Info Card -->

        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0">Internship Information</h4>
                    <span class="badge bg-warning text-dark fs-6 px-3 py-2">Pending</span>
                </div>

                <div class="row g-4">

                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Full Name</label>
                        <div class="form-control bg-light">@Model.FullName</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Department</label>
                        <div class="form-control bg-light">@Model.Department</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Start Date</label>
                        <div class="form-control bg-light">@Model.StartDate.ToShortDateString()</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">End Date</label>
                        <div class="form-control bg-light">@Model.EndDate</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Hours Rendered</label>
                        <div class="form-control bg-light">@Model.HoursRendered</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Required Hours</label>
                        <div class="form-control bg-light">@Model.RequiredHours</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Shift Start</label>
                        <div class="form-control bg-light">@Model.ShiftStart.ToShortTimeString()</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Shift End</label>
                        <div class="form-control bg-light">@Model.ShiftEnd.ToShortTimeString()</div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Approval Actions -->
        <div class="d-flex flex-wrap gap-2">

            <form asp-action="ApproveProfile" asp-controller="Hr" method="post">
                <input type="hidden" name="Id" value="@Model.ProfileId" />
                <button type="submit" class="btn btn-success px-4">Approve</button>
            </form>

            <form asp-action="DenyProfile" asp-controller="Hr" method="post">
                <input type="hidden" name="Id" value="@Model.ProfileId" />
                <button type="submit" class="btn btn-danger px-4">Deny</button>
            </form>

            <a asp-action="Dashboard" asp-controller="Hr" class="btn btn-secondary px-4">Back</a>

        </div>

    </div>

</body>
</html>