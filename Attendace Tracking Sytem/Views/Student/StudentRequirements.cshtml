@model Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentRequirementStatusUpdatePageVM

@{
    Layout = "~/Views/Shared/StudentSidebarLayout.cshtml";
}

<div class="container-fluid py-4 px-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h3 class="fw-bold mb-1">Submitted Requirements</h3>
        <small class="text-muted">Review feedback from HR and your uploaded documents</small>
    </div>

    @{
        bool? verified = Model.Verified;
    }

    <!-- VERIFICATION STATUS -->
    <div class="mb-4">

        @if (verified == true)
        {
            <div class="alert alert-success mb-0">
                <i class="bi bi-check-circle-fill me-2"></i>
                All documents have been verified by HR.
            </div>
        }
        else if (verified == false)
        {
            <div class="alert alert-danger mb-0">
                <i class="bi bi-x-circle-fill me-2"></i>
                Documents were reviewed but not approved by HR.
            </div>
        }
        else
        {
            <div class="alert alert-warning mb-0">
                <i class="bi bi-hourglass-split me-2"></i>
                Documents are pending verification.
            </div>
        }

    </div>

    <!-- HR MESSAGE -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h6 class="fw-bold mb-2">HR Remarks</h6>

            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert alert-info mb-0">
                    @Model.Message
                </div>
            }
            else
            {
                <div class="text-muted">
                    No feedback yet from HR.
                </div>
            }
        </div>
    </div>

    <div class="row g-4">

        <!-- NBI -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">

                    <h6 class="fw-bold mb-3">NBI Clearance</h6>

                    @if (!string.IsNullOrEmpty(Model.NBIImagePath))
                    {
                        <img src="@Model.NBIImagePath"
                             class="img-fluid rounded mb-3"
                             style="max-height: 200px;" />

                        <span class="badge bg-success">Uploaded</span>
                    }
                    else
                    {
                        <div class="text-muted mb-3">No file uploaded</div>
                        <span class="badge bg-danger">Missing</span>
                    }

                </div>
            </div>
        </div>

        <!-- MOA -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">

                    <h6 class="fw-bold mb-3">Memorandum of Agreement</h6>

                    @if (!string.IsNullOrEmpty(Model.MemorandumOfAgreementImagePath))
                    {
                        <img src="@Model.MemorandumOfAgreementImagePath"
                             class="img-fluid rounded mb-3"
                             style="max-height: 200px;" />

                        <span class="badge bg-success">Uploaded</span>
                    }
                    else
                    {
                        <div class="text-muted mb-3">No file uploaded</div>
                        <span class="badge bg-danger">Missing</span>
                    }

                </div>
            </div>
        </div>

        <!-- STUDENT ID -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">

                    <h6 class="fw-bold mb-3">Student ID</h6>

                    @if (!string.IsNullOrEmpty(Model.StudentIdImagePath))
                    {
                        <img src="@Model.StudentIdImagePath"
                             class="img-fluid rounded mb-3"
                             style="max-height: 200px;" />

                        <span class="badge bg-success">Uploaded</span>
                    }
                    else
                    {
                        <div class="text-muted mb-3">No file uploaded</div>
                        <span class="badge bg-danger">Missing</span>
                    }

                </div>
            </div>
        </div>

    </div>

</div>