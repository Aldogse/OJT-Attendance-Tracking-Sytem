@model Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentDashboardVM


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/studentDashboard.css" />
</head>
<body>

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom py-3 mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">
                <i class="bi bi-mortarboard-fill me-2"></i>Student Portal
            </a>

            <div class="ms-auto d-flex align-items-center gap-3">
                <span class="text-muted">Welcome, <strong>@Model.FullName</strong></span>
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                     style="width: 42px; height: 42px; font-weight: 600;">
                    @Model.FullName.Substring(0, 1)
                </div>
            </div>
        </div>
    </nav>

    <div class="container pb-5">

        <!-- Hero Section -->
        <div class="card dashboard-card mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h2 class="fw-bold mb-2">Hello, @Model.FullName 👋</h2>
                        <p class="sub-text mb-3">
                            Monitor your internship progress, attendance logs, and rendered hours all in one place.
                        </p>

                        <div class="mb-2 d-flex justify-content-between">
                            <span class="fw-semibold">OJT Progress</span>
                            <span class="fw-semibold">@Model.HoursRendered / 300 hrs</span>
                        </div>

                        <div class="progress">
                            <div class="progress-bar" role="progressbar"
                                 style="width: @(((Model.HoursRendered ?? 0) / 300) * 100)%;">
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 text-md-end mt-4 mt-md-0">
                        <button class="btn btn-success rounded-pill px-4 me-2">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Punch In
                        </button>
                        <button class="btn btn-danger rounded-pill px-4">
                            <i class="bi bi-box-arrow-left me-2"></i>Punch Out
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats -->
        <div class="row g-4 mb-4">

            <div class="col-md-6 col-lg-3">
                <div class="card stat-card h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-building"></i>
                        </div>
                        <div>
                            <p class="mb-1 text-muted small">Department</p>
                            <h6 class="mb-0 fw-bold">@Model.Department</h6>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card stat-card h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-success bg-opacity-10 text-success">
                            <i class="bi bi-calendar-event"></i>
                        </div>
                        <div>
                            <p class="mb-1 text-muted small">Start Date</p>
                            <h6 class="mb-0 fw-bold">@Model.StartDate</h6>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card stat-card h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-warning bg-opacity-10 text-warning">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                        <div>
                            <p class="mb-1 text-muted small">End Date</p>
                            <h6 class="mb-0 fw-bold">@Model.EndDate</h6>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card stat-card h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-info bg-opacity-10 text-info">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <div>
                            <p class="mb-1 text-muted small">Hours Rendered</p>
                            <h6 class="mb-0 fw-bold">@Model.HoursRendered hrs</h6>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Main Content -->
        <div class="row g-4">

            <!-- Attendance Logs -->
            <div class="col-lg-8">
                <div class="card dashboard-card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h5 class="section-title mb-1">Recent Attendance Logs</h5>
                                <p class="sub-text mb-0">Your latest recorded attendance sessions</p>
                            </div>
                            <button class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                View All
                            </button>
                        </div>

                        @if (Model.StudentLogs != null && Model.StudentLogs.Any())
                        {
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>#</th>
                                            <th>Date</th>
                                            <th>Time In</th>
                                            <th>Time Out</th>
                                            <th>Total Hours</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            int count = 1;
                                        }

                                        @foreach (var log in Model.StudentLogs)
                                        {
                                            <tr>
                                                <td>@count</td>
                                                <td>@log.LogDate</td>
                                                <td>@log.TimeIn</td>
                                                <td>@log.TimeOut</td>
                                                <td>@log.TotalHours</td>
                                                <td>
                                                    @if (log.Status == Attendace_Tracking_Sytem.Enums.AttendanceStatus.Complete)
                                                    {
                                                        <span class="badge-soft-success">Completed</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge-soft-warning">Incomplete</span>
                                                    }
                                                </td>
                                            </tr>
                                            count++;
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info rounded-4 mb-0">
                                No attendance logs available yet.
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Side Panel -->
            <div class="col-lg-4">
                <div class="card dashboard-card mb-4">
                    <div class="card-body p-4">
                        <h5 class="section-title mb-3">Internship Overview</h5>

                        <div class="mb-3">
                            <label class="text-muted small">Student Name</label>
                            <div class="fw-semibold">@Model.FullName</div>
                        </div>

                        <div class="mb-3">
                            <label class="text-muted small">Department</label>
                            <div class="fw-semibold">@Model.Department</div>
                        </div>

                        <div class="mb-3">
                            <label class="text-muted small">Internship Period</label>
                            <div class="fw-semibold">@Model.StartDate - @Model.EndDate</div>
                        </div>

                        <div>
                            <label class="text-muted small">Hours Progress</label>
                            <div class="fw-semibold">@Model.HoursRendered / 300 hrs completed</div>
                        </div>
                    </div>
                </div>

                <div class="card dashboard-card">
                    <div class="card-body p-4">
                        <h5 class="section-title mb-3">Quick Actions</h5>

                        <div class="d-grid gap-2">
                            <form asp-action="TimeIn" asp-controller="Student" method="post">
                                <button class="btn btn-success rounded-pill">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Punch In
                                </button>
                            </form>

                            <form asp-action="TimeOut" asp-controller="Student" method="post">
                                <button class="btn btn-danger rounded-pill">
                                    <i class="bi bi-box-arrow-left me-2"></i>Punch Out
                                </button>
                            </form>

                            <button class="btn btn-outline-primary rounded-pill">
                                <i class="bi bi-journal-text me-2"></i>View Full Attendance
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>

</body>
</html>
