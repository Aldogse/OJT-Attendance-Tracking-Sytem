@model Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentDashboardVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/Student/studentDashboard.css">
   
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">

        <h4><i class="bi bi-mortarboard-fill"></i> OJT System</h4>

        <a class="active" href="#">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <a href="#">
            <i class="bi bi-journal-text"></i> Attendance Logs
        </a>

        <a href="#">
            <i class="bi bi-person"></i> Profile
        </a>

    </div>

    <!-- MAIN -->
    <div class="main">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <strong>Success!</strong> @TempData["SuccessMessage"]

                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        <!-- TOP BAR -->
        <div class="topbar">

            <div>
                <strong>@Model.FullName</strong>
            </div>

            <div class="d-flex align-items-center gap-3">

                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                     style="width: 38px; height: 38px;">
                    @Model.FullName.Substring(0, 1)
                </div>

                <form asp-action="LogOut" asp-controller="Account" method="post">
                    <button class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>

            </div>

        </div>

        <!-- HERO -->
        <div class="card dashboard-card mb-4">
            <div class="card-body p-4">

                <h4 class="fw-bold">Hello, @Model.FullName 👋</h4>
                <p class="text-muted">Track your internship progress and attendance.</p>

                <div class="d-flex justify-content-between">
                    <span>Progress</span>
                    <span>@Model.HoursRendered / 300 hrs</span>
                </div>

                <div class="progress mt-2">
                    <div class="progress-bar"
                         style="width: @(((Model.HoursRendered ?? 0) / 300) * 100)%;">
                    </div>
                </div>

            </div>
        </div>

        <!-- ATTENDANCE -->
        <div class="card dashboard-card mb-4 text-center">
            <div class="card-body p-4">

                <h5>Attendance Action</h5>

                <div class="d-flex justify-content-center gap-3 mt-3">
                    <form asp-action="TimeIn" asp-controller="Student" method="post">
                        <button class="btn btn-success px-4">
                            Punch In
                        </button>
                    </form>

                    <form asp-action="TimeOut" asp-controller="Student" method="post">
                        <button class="btn btn-danger px-4">
                            Punch Out
                        </button>
                    </form>
                </div>

            </div>
        </div>

        <!-- TABLE -->
        <div class="card dashboard-card">
            <div class="card-body">

                <h5 class="mb-3">Recent Logs</h5>

                <table class="table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>In</th>
                            <th>Out</th>
                            <th>Hours</th>
                        </tr>
                    </thead>

                    <tbody>


                        @foreach (var log in Model.StudentLogs)
                        {
                            <tr>
                                <td>@log.Logdate</td>
                                <td>@log.Timein</td>
                                <td>@log.Timeout</td>
                                <td>@log.TotalHours</td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
            <nav>
                <ul class="pagination justify-content-center">

                    <!-- Previous -->
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link"   
                        asp-action="StudenDashboard"
                           asp-route-page="@(Model.CurrentPage - 1)">
                            Previous
                        </a>
                    </li>

                    <!-- Next -->
                    <li class="page-item @(Model.StudentLogs.Count < 5 ? "disabled" : "")">
                        <a class="page-link"
                           asp-route-page="@(Model.CurrentPage + 1)">
                            Next
                        </a>
                    </li>

                </ul>
            </nav>
        </div>

        <!-- EXISTING TABLE ABOVE (NO CHANGE) -->
        <!-- MISSED LOGS SECTION -->
        <div class="card dashboard-card mt-4">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0 text-danger">
                        <i class="bi bi-exclamation-circle me-2"></i>Missed Logs
                    </h5>

                    <span class="badge bg-danger">
                        @Model.MissedTimeouts?.Count()
                    </span>
                </div>

                @if (Model.MissedTimeouts != null && Model.MissedTimeouts.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle table-hover">

                            <thead class="table-light">
                                <tr>
                                    <th>Log ID</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var log in Model.MissedTimeouts)
                                {
                                    <tr>
                                        <td>@log.LogId</td>

                                        <td>
                                            @log.LogDate.ToString("MMMM dd, yyyy")
                                        </td>

                                        <td>
                                            <span class="badge bg-danger">
                                                Missed Timeout
                                            </span>
                                        </td>

                                        <td class="text-end">

                                            <a asp-action="MissedTimeoutDetails"
                                               asp-controller="Student"
                                               asp-route-ProfileId="@log.ProfileId"
                                               class="btn btn-sm btn-outline-primary">

                                                <i class="bi bi-arrow-right-circle"></i> View
                                            </a>

                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-success mb-0">
                        No missed logs recorded.
                    </div>
                }

            </div>
        </div>

    </div>

</body>
</html>