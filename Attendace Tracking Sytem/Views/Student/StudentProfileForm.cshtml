@using Attendace_Tracking_Sytem.Enums
@model Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentProfileVM

<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Profile Setup</title>

    
    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    

</head>
<body class="bg-light">

    <div class="container mt-5">
        <div class="card shadow rounded-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Student Profile Setup</h4>
            </div>

            
            <div class="card-body">
                <div asp-validation-summary="All" class="text-danger"></div>
                <form method="post" asp-action="StudentProfileForm" asp-controller="Student">

                    <input  type= "hidden" asp-for="UserId" /> 

                    <!-- Student ID -->
                    <div class="mb-3">
                        <label asp-for="StudentId">Student ID</label>
                        <input type="text" asp-for="StudentId" class="form-control" required maxlength="50">
                        <span asp-validation-for="StudentId" class="text-danger"></span>
                    </div>

                    <!-- School -->
                    <div class="mb-3">
                        <label class="form-label">School</label>
                        <input type="text" asp-for="School" class="form-control" required maxlength="50">
                        <span asp-validation-for="School" class="text-danger"></span>
                    </div>

                    <!-- Work Details -->
                    <div class="row">
                        <!-- Work Details -->
                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label asp-for="Department" class="form-label"></label>

                                <select asp-for="Department"
                                        asp-items="Html.GetEnumSelectList<Departments>()"
                                        class="form-select">

                                    <option value="">-- Select Department --</option>

                                </select>

                                <span asp-validation-for="Department" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <input type="date" asp-for="StartDate" class="form-control" required>
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <input type="date" asp-for="EndDate" class="form-control" required>
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Name Row -->
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">First Name</label>
                            <input type="text" asp-for="Firstname" class="form-control" required maxlength="50">
                            <span asp-validation-for="Firstname" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Middle Name</label>
                            <input type="text" asp-for="MiddleName" class="form-control" required maxlength="50">
                            <span asp-validation-for="MiddleName" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Last Name</label>
                            <input type="text" asp-for="LastName" class="form-control" required maxlength="50">
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Age -->
                    <div class="mb-3">
                        <label class="form-label">Age</label>
                        <input type="number" asp-for="Age" class="form-control" required min="1">
                        <span asp-validation-for="Age" class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" asp-for="Email" class="form-control" required>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- Phone Number -->
                    <div class="mb-3">
                        <label class="form-label">Phone Number</label>
                        <input type="text" asp-for="PhoneNumber" class="form-control" required>
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <!-- Submit -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-success">
                            Submit Profile
                        </button>
                    </div>

                </form>
            </div>
        </div>
        

    </div>

</body>
</html>
