@model Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentMissedLogDetailsVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Missed Log Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f5f7fb;
        }

        .form-card {
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>

    <div class="container py-5">

        <div class="row justify-content-center">
            <div class="col-lg-6">

                <div class="card form-card border-0">
                    <div class="card-body p-4">

                        <!-- Header -->
                        <div class="mb-4 text-center">
                            <h4 class="fw-bold">Missed Log Details</h4>
                            <p class="text-muted small">
                                Provide your explanation and correct your missing timeout.
                            </p>
                        </div>

                        <form method="post">

                            <!-- ✅ MUST NOT BE DISABLED -->
                            <input type="hidden" asp-for="ProfileId" />

                            <!-- Display fields (readonly instead of disabled) -->
                            <div class="mb-3">
                                <label class="form-label">Full Name</label>
                                <input asp-for="Fullname" class="form-control" readonly />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Department</label>
                                <input asp-for="Department" class="form-control" readonly />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Log Date</label>
                                <input asp-for="Logdate" class="form-control" readonly />
                            </div>

                            <!-- 🔥 TIMEOUT (BOUND TO MODEL) -->
                            <div class="mb-3">
                                <label class="form-label">Time Out</label>

                                <input asp-for="Timeout"
                                       type="time"
                                       class="form-control" />

                                <span asp-validation-for="Timeout" class="text-danger small"></span>

                                <small class="text-muted">
                                    Enter the correct time you ended your shift.
                                </small>
                            </div>

                            <!-- Explanation -->
                            <div class="mb-3">
                                <label class="form-label">Explanation</label>

                                <textarea asp-for="Explanation"
                                          class="form-control"
                                          rows="4"
                                          placeholder="Explain why you missed your timeout..."></textarea>

                                <span asp-validation-for="Explanation" class="text-danger small"></span>
                            </div>

                            <!-- Buttons -->
                            <div class="d-flex justify-content-between mt-4">

                                <a href="/Student/Dashboard" class="btn btn-outline-secondary">
                                    Back
                                </a>

                                <button type="submit" class="btn btn-primary">
                                    Submit Correction
                                </button>

                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>

    </div>

</body>
</html>