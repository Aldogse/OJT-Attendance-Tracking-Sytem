@model Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentMissedLogDetailsVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Missed Log Details</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f5f7fb;
        }

        .form-card {
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .section-title {
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="container py-5">

        <div class="row justify-content-center">
            <div class="col-lg-6">

                <div class="card form-card border-0">
                    <div class="card-body p-4">

                        <!-- Header -->
                        <div class="mb-4 text-center">
                            <h4 class="fw-bold">Missed Log Details</h4>
                            <p class="text-muted small">
                                Please review and provide explanation for the missed timeout.
                            </p>
                        </div>

                        <form method="post">

                            <!-- Profile ID (hidden if needed) -->
                            <input type="hidden" disabled asp-for="ProfileId" />

                            <!-- Full Name -->
                            <div class="mb-3">
                                <label class="form-label">Full Name</label>
                                <input asp-for="Fullname" class="form-control" readonly disabled />
                            </div>

                            <!-- Department -->
                            <div class="mb-3">
                                <label class="form-label">Department</label>
                                <input asp-for="Department" class="form-control" readonly disabled />
                            </div>

                            <!-- Log Date -->
                            <div class="mb-3">
                                <label class="form-label">Log Date</label>
                                <input asp-for="Logdate" class="form-control" readonly disabled/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Time Out</label>
                                <input type="time" name="TimeOut" class="form-control" required />
                                <small class="text-muted">
                                    Please enter the correct time you ended your shift.
                                </small>
                            </div>

                            <!-- Explanation -->
                            <div class="mb-3">
                                <label class="form-label">Explanation</label>
                                <textarea asp-for="Explanation"
                                          class="form-control"
                                          rows="4"
                                          placeholder="Enter your explanation here..."></textarea>
                                <span asp-validation-for="Explanation" class="text-danger small"></span>
                            </div>

                            <!-- Buttons -->
                            <div class="d-flex justify-content-between mt-4">

                                <a href="/Student/Dashboard" class="btn btn-outline-secondary">
                                    Back
                                </a>

                                <button type="submit" class="btn btn-primary">
                                    Submit Explanation
                                </button>

                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>

    </div>

</body>
</html>