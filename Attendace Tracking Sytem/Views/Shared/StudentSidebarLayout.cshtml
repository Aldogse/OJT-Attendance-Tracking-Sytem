<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Student Panel</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Your CSS -->
    <link rel="stylesheet" href="/css/Student/studentDashboard.css">
</head>

<body>

    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="bg-dark text-white p-3" style="width: 250px; min-height: 100vh;">

            <h4 class="mb-4">
                <i class="bi bi-mortarboard-fill"></i> OJT System
            </h4>

            <nav class="nav flex-column">

                <a class="nav-link text-white mb-2"
                   asp-controller="Student"
                   asp-action="StudentDashboard">
                    <i class="bi bi-folder-check me-2"></i> Dashboard
                </a>

                <a class="nav-link text-white mb-2"
                   asp-controller="Student"
                   asp-action="AttendanceLogs">
                    <i class="bi bi-folder-check me-2"></i> Attendance Logs
                </a>

                <a class="nav-link text-white mb-2" href="#">
                    <i class="bi bi-person me-2"></i> Profile
                </a>

                <a class="nav-link text-white mb-2"
                   asp-controller="Student"
                   asp-action="StudentRequirements">
                    <i class="bi bi-folder-check me-2"></i> Requirements
                </a>

            </nav>

        </div>

        <!-- MAIN CONTENT -->
        <div class="flex-grow-1 p-4">

            @RenderBody()  <!-- 🔥 THIS FIXES YOUR ERROR -->

        </div>

    </div>

</body>
</html>