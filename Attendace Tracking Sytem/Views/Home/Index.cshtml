<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OJT Attendance System</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/index.css" />
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
        <a class="navbar-brand fw-bold" href="#">OJT System</a>

        <div class="ms-auto">
            @{
                <a asp-action="LoginPage" 
                 asp-controller="Account"
                class="btn btn-outline-light btn-sm">
                     Login
                </a>
            }
        </div>
    </nav>

    <!-- HERO -->
    <section class="hero d-flex align-items-center text-center">
        <div class="container hero-content">

            <h1 class="display-5 fw-bold">
                OJT Attendance Management System
            </h1>

            <p class="lead mt-3">
                Track attendance, manage student progress, and streamline your internship workflow efficiently.
            </p>

            <div class="mt-4">
                @{
                    <a asp-action="LoginPage"
                       asp-controller="Account"
                       class="btn btn-outline-light btn-sm">
                        Login
                    </a>
                }

                <a href="#features" class="btn btn-outline-light btn-main">
                    Learn More
                </a>
            </div>

        </div>
    </section>

    <!-- FEATURES -->
    <section id="features" class="section bg-light">
        <div class="container text-center">

            <h2 class="fw-bold mb-4">System Features</h2>

            <div class="row g-4">

                <div class="col-md-4">
                    <div class="p-4 shadow-sm rounded bg-white">
                        <h5 class="fw-bold">Attendance Tracking</h5>
                        <p class="text-muted">
                            Monitor student time-in and time-out efficiently in real-time.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="p-4 shadow-sm rounded bg-white">
                        <h5 class="fw-bold">Progress Monitoring</h5>
                        <p class="text-muted">
                            Track required hours and student performance easily.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="p-4 shadow-sm rounded bg-white">
                        <h5 class="fw-bold">HR Management</h5>
                        <p class="text-muted">
                            Manage student approvals and oversee internship status.
                        </p>
                    </div>
                </div>

            </div>

        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-3">
        <small>© 2026 OJT Attendance System. All rights reserved.</small>
    </footer>

</body>
</html>