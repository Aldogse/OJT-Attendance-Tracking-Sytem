<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>
        Attendance Tracking System
    </title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        body
        {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            font-family: Arial, Helvetica, sans-serif;
        }

        .hero-section
        {
            flex: 1;

            background:
                linear-gradient(
                    rgba(0, 0, 0, 0.75),
                    rgba(0, 0, 0, 0.75)
                ),

                url('https://images.unsplash.com/photo-1497366754035-f200968a6e72?q=80&w=2070&auto=format&fit=crop');

            background-size: cover;
            background-position: center;

            color: white;

            display: flex;
            align-items: center;
        }

        .feature-box
        {
            background-color: rgba(255,255,255,0.08);

            border-radius: 12px;

            padding: 15px;

            margin-bottom: 15px;

            backdrop-filter: blur(4px);
        }

        footer
        {
            background-color: #111827;
        }

    </style>

</head>

<body>

    <!-- NAVBAR -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">

        <div class="container">

            <a class="navbar-brand fw-bold"
               href="#">

                <i class="bi bi-clipboard-check-fill"></i>

                Attendance Tracking System

            </a>

            <div class="ms-auto">

              @{
                    <a asp-controller="Account"
                       asp-action="LoginPage"
                        class="btn btn-primary">

                        <i class="bi bi-person-fill"></i>

                        Login
                    </a>
                }

            </div>

        </div>

    </nav>

    <!-- HERO SECTION -->

    <section class="hero-section py-5">

        <div class="container">

            <div class="row align-items-center">

                <div class="col-lg-6">

                    <h1 class="display-3 fw-bold mb-4">

                        Smarter Attendance.
                        <br>
                        Better Internships.

                    </h1>

                    <p class="lead mb-5">

                        The Attendance Tracking System
                        is designed to help students,
                        coordinators, and HR personnel
                        manage internship attendance
                        and requirements efficiently,
                        accurately, and in real-time.

                    </p>

                    <!-- FEATURES -->

                    <div class="feature-box">

                        <h5>

                            <i class="bi bi-people-fill"></i>

                            Track and Monitor Attendance

                        </h5>

                        <p class="mb-0">

                            Keep accurate attendance
                            logs and monitor student
                            performance in real-time.

                        </p>

                    </div>

                    <div class="feature-box">

                        <h5>

                            <i class="bi bi-file-earmark-text-fill"></i>

                            Manage Internship Applications

                        </h5>

                        <p class="mb-0">

                            Review, approve,
                            and organize student
                            internship applications.

                        </p>

                    </div>

                    <div class="feature-box">

                        <h5>

                            <i class="bi bi-cloud-arrow-up-fill"></i>

                            Upload Requirements

                        </h5>

                        <p class="mb-0">

                            Students can upload
                            resumes, MOA, IDs,
                            and other required documents.

                        </p>

                    </div>

                    <div class="feature-box">

                        <h5>

                            <i class="bi bi-bar-chart-fill"></i>

                            Monitor OJT Progress

                        </h5>

                        <p class="mb-0">

                            Easily track internship
                            progress and completion status.

                        </p>

                    </div>


                </div>

            </div>

        </div>

    </section>

    <!-- FOOTER -->

    <footer class="text-white py-4">

        <div class="container text-center">

            <h5 class="fw-bold">

                Developed By

            </h5>

            <p class="mb-1">

                Ezekiel Lamoste

            </p>

            <p>

                <i class="bi bi-envelope-fill"></i>

                ezekiellamoste4@gmail.com

            </p>

            <hr class="border-secondary">

            <p class="mb-0">

                © 2026 Attendance Tracking System.
                All Rights Reserved.

            </p>

        </div>

    </footer>

</body>

</html>