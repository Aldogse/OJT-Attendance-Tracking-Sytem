@model Attendace_Tracking_Sytem.ViewModels.HR_DASHBOARD_VM.HrDashBoardVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HR Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/Hr/hrDashboard.css" rel="stylesheet">
    
</head>
<body>

    <!-- MAIN -->
    <div class="main">

        @{
            Layout = "~/Views/Shared/HrSidebarLayout.cshtml";
        }

        <!-- SUMMARY -->
        <div class="row g-4 mb-4">

            <div class="col-md-4">
                <div class="card dashboard-card p-4">
                    <div class="stat-title">Active Students</div>
                    <h3 class="fw-bold">@Model.NumberOfActiveStudents</h3>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card p-4">
                    <div class="stat-title">Pending Students</div>
                    <h3 class="fw-bold">@(Model.PendingStudents?.Count ?? 0)</h3>
                </div>
            </div>

        </div>

        <!-- ATTENDANCE TREND -->
        <div class="card dashboard-card mb-4">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">
                        Attendance Trend
                    </h5>
                </div>

                <!-- FILTER -->
                <form method="get"
                      asp-action="HrDashBoard"
                      asp-controller="HR"
                      class="mb-4">

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">
                                Start Date
                            </label>

                            <input type="date"
                                   name="startDate"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">
                                End Date
                            </label>

                            <input type="date"
                                   name="endDate"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit"
                                    class="btn btn-primary w-100">
                                Apply Filter
                            </button>
                        </div>

                    </div>

                </form>

                @if (Model.attendanceTrend != null &&
                                Model.attendanceTrend.Any())
                {
                    <canvas id="attendanceTrendChart"
                            height="100">
                    </canvas>
                }
                else
                {
                    <div class="alert alert-info">
                        No attendance trend data available.
                    </div>
                }

            </div>

        </div>

        <!-- PENDING STUDENTS -->
        <div class="card dashboard-card mb-4">
            <div class="card-body">

                <h5 class="fw-bold mb-3">Pending Student Approvals</h5>

                @if (Model.PendingStudents != null && Model.PendingStudents.Any())
                {
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>School</th>
                                <th>Department</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var student in Model.PendingStudents)
                            {
                                <tr>
                                    <td>@student.FirstName @student.LastName</td>
                                    <td>@student.School</td>
                                    <td>@student.Department</td>
                                    <td><span class="badge bg-warning text-dark">Pending</span></td>
                                    <td>
                                        <a asp-action="HrPendingStudentDetails"
                                           asp-controller="Student"
                                           asp-route-ProfileId="@student.ProfileId"
                                           class="btn btn-sm btn-outline-primary">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-success">No pending students.</div>
                }

            </div>
        </div>

        <!-- STUDENTS WITH 3+ ABSENCES -->
        <div class="card dashboard-card mb-4">

            <div class="card-body">

                <h5 class="fw-bold mb-3 text-danger">
                    Students With 3 or More Absences
                </h5>

                @if (Model.absentDetails != null &&
                                Model.absentDetails.Any())
                {
                    <div class="table-responsive">

                        <table class="table table-hover align-middle">

                            <thead class="table-light">
                                <tr>
                                    <th>Student ID</th>
                                    <th>First Name</th>
                                    <th>Last Name</th>
                                    <th>School</th>
                                    <th>Department</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var student in Model.absentDetails)
                                {
                                    <tr>
                                        <td>@student.StudentId</td>
                                        <td>@student.FirstName</td>
                                        <td>@student.Lastname</td>
                                        <td>@student.School</td>
                                        <td>@student.Department</td>
                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>
                }
                else
                {
                    <div class="alert alert-success mb-0">
                        No student has 3 or more absences.
                    </div>
                }

            </div>

        </div>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @if (Model.attendanceTrend != null &&
        Model.attendanceTrend.Any())
    {
        <script>

            const labels = [
                @Html.Raw(string.Join(",",
                    Model.attendanceTrend.Select(
                            x => $"'{x.attendanceDate:MMM dd}'")))
        ];

        const presentData = [
            @Html.Raw(string.Join(",",
                                Model.attendanceTrend.Select(
                                        x => x.numberOfPresent ?? 0)))
        ];

        const lateData = [
            @Html.Raw(string.Join(",",
                                Model.attendanceTrend.Select(
                                        x => x.numberOfLates ?? 0)))
        ];

        const absentData = [
            @Html.Raw(string.Join(",",
                                Model.attendanceTrend.Select(
                                        x => x.numberOfAbsents ?? 0)))
        ];

        new Chart(
            document.getElementById('attendanceTrendChart'),
            {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Present',
                            data: presentData,
                            borderColor: '#198754',
                            tension: 0.3
                        },
                        {
                            label: 'Late',
                            data: lateData,
                            borderColor: '#ffc107',
                            tension: 0.3
                        },
                        {
                            label: 'Absent',
                            data: absentData,
                            borderColor: '#dc3545',
                            tension: 0.3
                        }
                    ]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
    </script>
        }

</body>
</html>