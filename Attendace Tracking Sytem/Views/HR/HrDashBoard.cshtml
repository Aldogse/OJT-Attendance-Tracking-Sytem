@model Attendace_Tracking_Sytem.ViewModels.HR_DASHBOARD_VM.HrDashBoardVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HR Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/Hr/hrDashboard.css" rel="stylesheet">
    
</head>
<body>

    <!-- MAIN -->
    <div class="main">

        @{
            Layout = "~/Views/Shared/HrSidebarLayout.cshtml";
        }

        <!-- SUMMARY -->
        <div class="row g-4 mb-4">

            <div class="col-md-4">
                <div class="card dashboard-card p-4">
                    <div class="stat-title">Active Students</div>
                    <h3 class="fw-bold">@Model.NumberOfActiveStudents</h3>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card p-4">
                    <div class="stat-title">Pending Students</div>
                    <h3 class="fw-bold">@Model.PendingStudents.Count</h3>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card dashboard-card p-4">
                    <div class="stat-title">Finishing Students</div>
                    <h3 class="fw-bold">@Model.FinishingStudents</h3>
                </div>
            </div>

        </div>

        <!-- PENDING STUDENTS -->
        <div class="card dashboard-card mb-4">
            <div class="card-body">

                <h5 class="fw-bold mb-3">Pending Student Approvals</h5>

                @if (Model.PendingStudents != null && Model.PendingStudents.Any())
                {
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>School</th>
                                <th>Department</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var student in Model.PendingStudents)
                            {
                                <tr>
                                    <td>@student.FirstName @student.LastName</td>
                                    <td>@student.School</td>
                                    <td>@student.Department</td>
                                    <td><span class="badge bg-warning text-dark">Pending</span></td>
                                    <td>
                                        <a asp-action="HrPendingStudentDetails"
                                           asp-controller="Student"
                                           asp-route-ProfileId="@student.ProfileId"
                                           class="btn btn-sm btn-outline-primary">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-success">No pending students.</div>
                }

            </div>
        </div>

        <!-- MISSED LOGS -->
        <div class="card dashboard-card">
            <div class="card-body">

                <h5 class="fw-bold text-danger mb-3">
                    Missed Timeouts (@Model.MissedTimeouts?.Count())
                </h5>

                @if (Model.MissedTimeouts != null && Model.MissedTimeouts.Any())
                {
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Log ID</th>
                                <th>Profile</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var log in Model.MissedTimeouts)
                            {
                                <tr>
                                    <td>@log.LogId</td>
                                    <td>@log.ProfileId</td>
                                    <td>@log.LogDate.ToString("MMMM dd, yyyy")</td>
                                    <td><span class="badge bg-danger">Missed</span></td>
                                    <td>
                                        <a asp-action="MissedLogDetails"
                                           asp-controller="Hr"
                                           asp-route-ProfileId="@log.ProfileId"
                                           class="btn btn-sm btn-outline-dark">
                                            Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-success">No missed logs.</div>
                }

            </div>
        </div>

    </div>

</body>
</html>