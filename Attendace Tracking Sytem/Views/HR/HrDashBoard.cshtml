@model Attendace_Tracking_Sytem.ViewModels.HR_DASHBOARD_VM.HrDashBoardVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HR Dashboard</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container py-4"  >   
        <!-- Header -->
        <div class="mb-4">
            <h2 class="fw-bold">HR Dashboard</h2>
            <p class="text-muted mb-0">Welcome, @Model.FullName</p>
        </div>

        <!-- Summary Cards -->
        <div class="row g-4 mb-4">

            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Active Students</h6>
                        <h2 class="fw-bold">@Model.NumberOfActiveStudents</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Pending Students</h6>
                        <h2 class="fw-bold">@Model.PendingStudents.Count</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Finishing Students</h6>
                        <h2 class="fw-bold">@Model.FinishingStudents</h2>
                    </div>
                </div>
            </div>

        </div>

        <!-- Pending Students Table -->
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Pending Student Approvals</h5>

                @if (Model.PendingStudents != null && Model.PendingStudents.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Student Name</th>
                                    <th>Company</th>
                                    <th>Position</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var student in Model.PendingStudents)
                                {
                                    <tr>
                                        <td>@student.FirstName @student.LastName</td>
                                        <td>@student.School</td>
                                        <td>@student.Department</td>
                                        <td>
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        </td>
                                        <td>
                                            <a asp-action="HrPendingStudentDetails" asp-controller="Student" asp-route-ProfileId="@student.ProfileId" class="btn btn-sm btn-primary">
                                                View
                                            </a>
                                        </td>
                                    </tr>                                                  
                                }
                                
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-success mb-0">
                        No pending students at the moment.
                    </div>
                }
            </div>
        </div>

        <!-- Missed Logs Table -->
        <div class="card shadow-sm border-0 rounded-4 mt-4">
            <div class="card-body">
                <h5 class="fw-bold mb-3 text-danger">Missed Timeouts: @Model.MissedTimeouts?.Count()</h5>

                @if (Model.MissedTimeouts != null && Model.MissedTimeouts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Log ID</th>
                                    <th>Student Work Profile ID</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Action </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.MissedTimeouts)
                                {
                                    <tr>
                                        <td>@log.LogId</td>
                                        <td>@log.ProfileId</td>
                                        <td>@log.LogDate.ToString("MMMM dd, yyyy")</td>
                                        <td>
                                            <span class="badge bg-danger">Missed Timeout</span>
                                        </td>
                                        <td>
                                            <a asp-action="MissedLogDetails"
                                               asp-controller="Hr"
                                               asp-route-ProfileId="@log.ProfileId"
                                               class="btn btn-sm btn-primary"
                                               title="View Details">
                                                <i class="bi bi-arrow-right-circle-fill fs-5"></i>  
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-success mb-0">
                        No missed timeouts recorded.
                    </div>
                }
            </div>
        </div>

    </div>

</body>
</html>
