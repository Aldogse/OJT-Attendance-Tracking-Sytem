@model List<Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentsMissedLogsVM>

@{
    Layout = "~/Views/Shared/HrSidebarLayout.cshtml";
}

<div class="container py-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Missed Timeouts</h3>
            <small class="text-muted">Review and manage student timeout issues</small>
        </div>

        <span class="badge bg-danger px-3 py-2">
            @(Model?.Count ?? 0) Records
        </span>
    </div>

    <!-- FILTERS -->
    <form asp-action="MissedLogs" asp-controller="Hr" method="get">
        <div class="card shadow-sm mb-4">
            <div class="card-body d-flex flex-wrap gap-3">

                <input name="date" type="date" class="form-control w-auto">

                <select name="status" class="form-select w-auto">
                    <option value="">All Status</option>
                    <option value="Pending">Pending</option>
                    <option value="Approved">Approved</option>
                    <option value="Rejected">Rejected</option>
                </select>

                <button class="btn btn-primary">Apply Filters</button>

            </div>
        </div>
    </form>

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover mb-0">

                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Log ID</th>
                            <th>Student</th>
                            <th>Date</th>
                            <th>Timeout</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            @foreach (var log in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-secondary">
                                        #@log.LogId
                                    </td>

                                    <td>
                                        <div class="fw-semibold">@log.Fullname</div>
                                    </td>

                                    <td>
                                        <div>@log.LogDate.ToString("MMM dd, yyyy")</div>
                                        <small class="text-muted">
                                            @log.LogDate.DayOfWeek
                                        </small>
                                    </td>

                                    <td>
                                        @if (log.Timeout.HasValue)
                                        {
                                            @log.Timeout.Value.ToString(@"hh\:mm")
                                        }
                                        else
                                        {
                                            <span class="text-muted">--</span>
                                        }
                                    </td>

                                    <td>
                                       <span class="badge px-3 py-2
                                         @(log.status == Attendace_Tracking_Sytem.Enums.MissedLogStatus.Pending 
                                                        ?"bg-warning-subtle text-warning"
                                                        :log.status == Attendace_Tracking_Sytem.Enums.MissedLogStatus.Approved ? "bg-success-subtle text-success" :
                                                        "bg-danger-subtle text-danger")">

                                        @log.status
                                       </span>
                                    </td>

                                    <td class="text-end pe-4">
                                        <a asp-action="MissedLogDetails"
                                           asp-controller="Hr"
                                           asp-route-ProfileId="@log.ProfileId"
                                           class="btn btn-sm btn-outline-primary">
                                            View →
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4">
                                    <div class="text-muted">No missed logs found.</div>
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>