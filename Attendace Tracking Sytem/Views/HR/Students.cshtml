@using Attendace_Tracking_Sytem.Enums
@model List<Attendace_Tracking_Sytem.ViewModels.HR_PAGES_VM.StudentVM>

@{
    Layout = "~/Views/Shared/HrSidebarLayout.cshtml";
}

<div class="container-fluid py-4 px-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Students</h3>
            <small class="text-muted">Manage and monitor student records</small>
        </div>

        <span class="badge bg-primary px-3 py-2">
            @(Model?.Count ?? 0) Students
        </span>
    </div>

    <!-- FILTER BAR -->
    <form asp-action="Students" method="get" class="mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex flex-wrap gap-3 align-items-center">

                <!-- Department Filter -->
                <div>
                    <label class="form-label mb-1 text-muted small">Department</label>
                    <select name="department"
                            class="form-select"
                            asp-items="Html.GetEnumSelectList<Departments>()">
                        <option value="">All Departments</option>
                    </select>
                </div>

                <!-- Submit -->
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        Apply Filter
                    </button>
                </div>

            </div>
        </div>
    </form>

    <!-- STUDENT GRID -->
    <div class="row g-4">

        @if (Model != null && Model.Any())
        {
            foreach (var student in Model)
            {
                <div class="col-xl-4 col-lg-6">

                    <div class="card border-0 shadow-sm h-100 rounded-4">

                        <div class="card-body">

                            <!-- PROFILE HEADER -->
                            <div class="d-flex align-items-center mb-3">

                                <!-- Avatar -->
                                <div class="rounded-circle bg-light d-flex justify-content-center align-items-center me-3"
                                     style="width: 60px; height: 60px;">
                                    <span class="fw-bold fs-5 text-secondary">
                                        @student.Fullname.Substring(0, 1)
                                    </span>
                                </div>

                                <!-- Name + ID -->
                                <div>
                                    <h6 class="fw-bold mb-0">@student.Fullname</h6>
                                    <small class="text-muted">ID: @student.StudentId</small>
                                </div>

                            </div>

                            <!-- DETAILS -->
                            <div class="mb-3">

                                <div class="d-flex justify-content-between mb-1">
                                    <small class="text-muted">Profile ID</small>
                                    <span class="fw-semibold">#@student.ProfileId</span>
                                </div>

                                <div class="d-flex justify-content-between">
                                    <small class="text-muted">Department</small>
                                    <span class="fw-semibold">@student.Department</span>
                                </div>

                            </div>

                            <!-- HOURS -->
                            <div class="mb-3">
                                <small class="text-muted">Hours Rendered</small>

                                <div class="d-flex justify-content-between">
                                    <span class="fw-semibold">@student.HoursRendered hrs</span>
                                </div>

                                <div class="progress mt-2" style="height: 8px;">
                                    <div class="progress-bar bg-success"
                                         role="progressbar"
                                         style="width: @(student.HoursRendered)%;"></div>
                                </div>
                            </div>

                            <!-- ACTIONS -->
                            <div class="d-flex gap-2 mt-3">

                                <a asp-action="StudentProfile"
                                   asp-controller="Hr"
                                   asp-route-ProfileId="@student.ProfileId"
                                   class="btn btn-sm btn-primary w-100">
                                    View Profile
                                </a>

                                <a asp-action="StudentLogsSummary"
                                   asp-controller="Hr"
                                   asp-route-profileId="@student.ProfileId"
                                   class="btn btn-sm btn-outline-primary w-100">
                                    Logs
                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="fs-1 mb-2">📭</div>
                <h6 class="fw-semibold">No students found</h6>
                <small class="text-muted">No records match your filter.</small>
            </div>
        }

    </div>

    <!-- PAGINATION -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            <!-- PREVIOUS -->
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Students"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-department="@Context.Request.Query["department"]">
                    ← Previous
                </a>
            </li>

            <!-- CURRENT -->
            <li class="page-item active">
                <span class="page-link">
                    @ViewBag.CurrentPage
                </span>
            </li>

            <!-- NEXT -->
            <li class="page-item @(Model.Count < ViewBag.PageSize ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Students"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-department="@Context.Request.Query["department"]">
                    Next →
                </a>
            </li>

        </ul>
    </nav>

</div>