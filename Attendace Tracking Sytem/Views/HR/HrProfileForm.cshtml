```cshtml
@model Attendace_Tracking_Sytem.ViewModels.HR_PAGES_VM.HrProfileVM

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>
        HR Profile Form
    </title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        body {
            background: linear-gradient( rgba(15, 23, 42, 0.82), rgba(15, 23, 42, 0.82) ), url('https://images.unsplash.com/photo-1521791136064-7986c2920216?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            font-family: Arial, Helvetica, sans-serif;
        }

        .profile-card {
            border: none;
            border-radius: 18px;
            overflow: hidden;
            background-color: rgba(255,255,255,0.98);
            backdrop-filter: blur(6px);
        }

        .card-header-custom {
            background-color: #0f172a;
            padding: 30px;
            border-bottom: 4px solid #1e293b;
        }

            .card-header-custom h2 {
                color: white;
                margin: 0;
                font-weight: 700;
            }

            .card-header-custom p {
                color: #cbd5e1;
                margin-top: 10px;
                margin-bottom: 0;
            }

        .form-label {
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 8px;
        }

        .form-control {
            border-radius: 10px;
            padding: 14px;
            border: 1px solid #cbd5e1;
            transition: all 0.2s ease;
        }

            .form-control:focus {
                border-color: #0f172a;
                box-shadow: 0 0 0 0.15rem rgba(15, 23, 42, 0.15);
            }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 20px;
            border-left: 4px solid #0f172a;
            padding-left: 12px;
        }

        .submit-btn {
            background-color: #0f172a;
            border: none;
            padding: 14px 24px;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.2s ease;
        }

            .submit-btn:hover {
                background-color: #1e293b;
                transform: translateY(-1px);
            }

        .clear-btn {
            padding: 14px 24px;
            border-radius: 10px;
            font-weight: 600;
        }

        .alert-danger {
            border-radius: 10px;
        }

    </style>

</head>

<body>

    <div class="container py-5">

        <div class="row justify-content-center">

            <div class="col-lg-8 col-md-10">

                <div class="card profile-card shadow-lg">

                    <!-- HEADER -->

                    <div class="card-header-custom">

                        <h2>

                            <i class="bi bi-building-fill-gear"></i>

                            HR Profile Setup

                        </h2>

                        <p>

                            Complete your human resources profile information

                        </p>

                    </div>

                    <!-- BODY -->

                    <div class="card-body p-5">

                        @if (ViewData.ModelState.ErrorCount > 0)
                        {
                            <div asp-validation-summary="All"
                                 class="alert alert-danger">
                            </div>
                        }

                        <form asp-action="HrProfileForm"
                              method="post">

                            <input type="hidden"
                                   asp-for="UserId" />

                            <!-- PERSONAL DETAILS -->

                            <div class="section-title">

                                Personal Information

                            </div>

                            <div class="row">

                                <!-- FIRST NAME -->

                                <div class="col-md-4 mb-4">

                                    <label asp-for="FirstName"
                                           class="form-label">

                                        First Name

                                    </label>

                                    <input asp-for="FirstName"
                                           class="form-control"
                                           placeholder="Enter first name">

                                    <span asp-validation-for="FirstName"
                                          class="text-danger">
                                    </span>

                                </div>

                                <!-- MIDDLE NAME -->

                                <div class="col-md-4 mb-4">

                                    <label asp-for="MiddleName"
                                           class="form-label">

                                        Middle Name

                                    </label>

                                    <input asp-for="MiddleName"
                                           class="form-control"
                                           placeholder="Enter middle name">

                                    <span asp-validation-for="MiddleName"
                                          class="text-danger">
                                    </span>

                                </div>

                                <!-- LAST NAME -->

                                <div class="col-md-4 mb-4">

                                    <label asp-for="LastName"
                                           class="form-label">

                                        Last Name

                                    </label>

                                    <input asp-for="LastName"
                                           class="form-control"
                                           placeholder="Enter last name">

                                    <span asp-validation-for="LastName"
                                          class="text-danger">
                                    </span>

                                </div>

                            </div>

                            <!-- EMPLOYEE DETAILS -->

                            <div class="section-title">

                                Employee Information

                            </div>

                            <!-- EMPLOYEE ID -->

                            <div class="mb-4">

                                <label asp-for="EmployeeId"
                                       class="form-label">

                                    Employee ID

                                </label>

                                <input asp-for="EmployeeId"
                                       class="form-control"
                                       placeholder="Enter employee ID">

                                <span asp-validation-for="EmployeeId"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- ADDRESS -->

                            <div class="mb-4">

                                <label asp-for="Address"
                                       class="form-label">

                                    Address

                                </label>

                                <input asp-for="Address"
                                       class="form-control"
                                       placeholder="Enter address">

                                <span asp-validation-for="Address"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- CONTACT NUMBER -->

                            <div class="mb-4">

                                <label asp-for="ContactNumber"
                                       class="form-label">

                                    Contact Number

                                </label>

                                <input asp-for="ContactNumber"
                                       class="form-control"
                                       placeholder="Enter contact number">

                                <span asp-validation-for="ContactNumber"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- BUTTONS -->

                            <div class="d-flex justify-content-between mt-4">

                                <button type="reset"
                                        class="btn btn-outline-secondary clear-btn">

                                    <i class="bi bi-arrow-counterclockwise"></i>

                                    Clear

                                </button>

                                <button type="submit"
                                        class="btn btn-primary submit-btn">

                                    <i class="bi bi-check-circle-fill"></i>

                                    Submit Profile

                                </button>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>
```
