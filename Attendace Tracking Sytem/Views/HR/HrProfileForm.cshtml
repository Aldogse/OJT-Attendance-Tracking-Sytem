@model Attendace_Tracking_Sytem.ViewModels.HR_PAGES_VM.HrProfileVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>HR Profile Form</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
                <div class="card shadow rounded-4 border-0">
                    <div class="card-body p-5">
                        <h2 class="text-center mb-4">HR Profile Form</h2>
                     
                        <form action="HrProfileForm" method="post">

                            <div asp-validation-summary="All"></div>
                            <input type="hidden" asp-for="UserId" />
                            <div class="row">
                                <!-- First Name -->
                                <div class="col-md-4 mb-3">
                                    <label asp-for="FirstName" class="form-label">First Name</label>
                                    <input type="text" class="form-control" asp-for="FirstName" placeholder="Enter first name">
                                </div>

                                <!-- Middle Name -->
                                <div class="col-md-4 mb-3">
                                    <label asp-for="MiddleName" class="form-label">Middle Name</label>
                                    <input type="text" class="form-control" asp-for="MiddleName" placeholder="Enter Middle name">
                                </div>

                                <!-- Last Name -->
                                <div class="col-md-4 mb-3">
                                    <label asp-for="LastName" class="form-label">Last Name</label>
                                    <input type="text" class="form-control" asp-for="LastName" placeholder="Enter last name">
                                </div>
                            </div>

                            <!-- Employee ID -->
                            <div class="mb-3">
                                <label asp-for="EmployeeId" class="form-label">Employee ID</label>
                                <input type="text" class="form-control"  asp-for="EmployeeId" placeholder="Enter employee ID">
                            </div>

                            <!-- Address -->
                            <div class="mb-3">
                                <label asp-for="Address" class="form-label">Address</label>
                                <input type="text" class="form-control" asp-for="Address" placeholder="Enter address">
                            </div>

                            <!-- Contact Number -->
                            <div class="mb-4">
                                <label asp-for="ContactNumber" class="form-label">Contact Number</label>
                                <input type="number" class="form-control" asp-for="ContactNumber" placeholder="Enter contact number">
                            </div>

                            <!-- Buttons -->
                            <div class="d-flex justify-content-between">
                                <button type="reset" class="btn btn-outline-secondary px-4 rounded-3">
                                    Clear
                                </button>
                                <button type="submit" class="btn btn-primary px-4 rounded-3">
                                    Submit
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>