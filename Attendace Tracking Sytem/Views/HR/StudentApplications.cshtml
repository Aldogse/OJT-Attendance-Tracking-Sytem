@model IEnumerable<Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentApplicationsVM>

@{
    Layout = "~/Views/Shared/HrSidebarLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>
        Student Applications
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

    <div class="container py-5">
        @if(TempData["Empty"] != null)
        {
            <div class="alert alert-warning">
                @TempData["Empty"]
            </div>
        }
        <div class="card shadow-sm">

            <div class="card-header bg-primary text-white">

                <h3 class="mb-0">
                    Student Applications
                </h3>

            </div>

            <div class="card-body">
                <div class="table-responsive">

                    <table class="table table-bordered table-hover align-middle">

                        <thead class="table-dark">

                            <tr>

                                <th>
                                    Full Name
                                </th>

                                <th>
                                    School
                                </th>

                                <th>
                                    Course
                                </th>

                                <th>
                                    Year
                                </th>

                                <th>
                                    Resume
                                </th>

                                <th>
                                    Status
                                </th>

                                <th>
                                    Application Date
                                </th>

                                <th>
                                    Action
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        @item.FullName
                                    </td>

                                    <td>
                                        @item.School
                                    </td>

                                    <td>
                                        @item.Course
                                    </td>

                                    <td>
                                        @item.Year
                                    </td>

                                    <td>

                                        @if (!string.IsNullOrEmpty(item.ResumePath))
                                        {
                                            <a href="@item.ResumePath"
                                               target="_blank"
                                               class="btn btn-sm btn-secondary">

                                                View Resume

                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                No Resume
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        <span class="badge bg-warning text-dark">

                                            @item.Status

                                        </span>

                                    </td>

                                    <td>

                                        @item.ApplicationDate
                                        .ToString("MMMM dd, yyyy")

                                    </td>

                                    <td>

                                        @* <a asp-action="ViewApplication"
                                           asp-controller="Student"
                                           asp-route-id="@item.Id"
                                           class="btn btn-primary btn-sm">

                                            View

                                        </a> *@

                                    </td>

                                </tr>
                        }

                        </tbody>

                    </table>


                </div>
                

            </div>

        </div>

    </div>

</body>

</html>