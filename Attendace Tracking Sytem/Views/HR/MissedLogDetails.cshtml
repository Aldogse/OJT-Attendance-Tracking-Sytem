@model Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentMissedLogDetailsVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Missed Log Details</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container mt-5">

        <div class="card shadow-lg border-0 rounded-4">

            <!-- Header -->
            <div class="card-header bg-danger text-white rounded-top-4">
                <h4 class="mb-0">Missed Timeout Details</h4>
            </div>

            <!-- Body -->
            <div class="card-body">

                <!-- Student Info -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted">Full Name</h6>
                        <h5 class="fw-bold">@Model.Fullname</h5>
                    </div>

                    <div class="col-md-6">
                        <h6 class="text-muted">Profile ID</h6>
                        <h5 class="fw-bold text-secondary">@Model.ProfileId</h5>
                    </div>
                </div>

                <hr />

                <!-- Work Info -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted">Department</h6>
                        <h5>@Model.Department</h5>
                    </div>

                    <div class="col-md-6">
                        <h6 class="text-muted">Log Date</h6>
                        <h5 class="text-danger">@Model.Logdate</h5>
                    </div>
                </div>

                <hr />

                <!-- Status -->
                <div class="mb-4">
                    <h6 class="text-muted">Status</h6>
                    <span class="badge bg-danger fs-6">Missed Timeout</span>
                </div>


            </div>
        </div>

    </div>

</body>
</html>