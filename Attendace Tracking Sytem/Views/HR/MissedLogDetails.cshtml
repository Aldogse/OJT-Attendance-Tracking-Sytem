@model Attendace_Tracking_Sytem.ViewModels.Student_Pages_VM.StudentMissedLogDetailsVM

@{
    Layout = "~/Views/Shared/HrSidebarLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Missed Log Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f5f7fb;
            font-family: 'Segoe UI', Tahoma, sans-serif;
        }

        .card-custom {
            border: none;
            border-radius: 14px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        }

        .section-title {
            font-size: 0.85rem;
            color: #6c757d;
            margin-bottom: 2px;
        }

        .value-text {
            font-weight: 600;
            font-size: 1rem;
        }

        .status-badge {
            font-size: 0.85rem;
            padding: 6px 12px;
        }

        .explanation-box {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 12px;
            border: 1px solid #e9ecef;
        }
    </style>
</head>
<body>

    <div class="container py-4">

        <div class="row justify-content-center">
            <div class="col-lg-7">

                <div class="card card-custom">
                    <div class="card-body p-4">

                        <!-- HEADER -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h4 class="fw-bold mb-0">Missed Timeout Details</h4>
                                <small class="text-muted">Review submitted correction</small>
                            </div>

                            <span class="badge bg-danger status-badge">
                                Missed Timeout
                            </span>
                        </div>

                        <!-- STUDENT INFO -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="section-title">Full Name</div>
                                <div class="value-text">@Model.Fullname</div>
                            </div>

                            <div class="col-md-6">
                                <div class="section-title">Profile ID</div>
                                <div class="value-text text-secondary">@Model.ProfileId</div>
                            </div>
                        </div>

                        <!-- WORK INFO -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="section-title">Department</div>
                                <div class="value-text">@Model.Department</div>
                            </div>

                            <div class="col-md-6">
                                <div class="section-title">Log Date</div>
                                <div class="value-text text-danger">@Model.Logdate</div>
                            </div>
                        </div>

                        <!-- 🔥 TIME OUT (NEW) -->
                        <div class="mb-4">
                            <div class="section-title">Time Out</div>

                            <div class="value-text">
                                @if (Model.Timeout != null)
                                {
                                    @Model.Timeout.Value.ToString(@"hh\:mm")
                                }
                                else
                                {
                                    <span class="text-muted">Not provided</span>
                                }
                            </div>
                        </div>

                        <!-- EXPLANATION -->
                        <div class="mb-4">
                            <div class="section-title">Explanation</div>

                            <div class="explanation-box mt-2">
                                @if (!string.IsNullOrEmpty(Model.Explanation))
                                {
                                    @Model.Explanation
                                }
                                else
                                {
                                    <span class="text-muted">No explanation submitted.</span>
                                }
                            </div>
                        </div>

                        <!-- ACTION -->
                        <div class="d-flex justify-content-between mt-4">

                            <a href="/Hr/Dashboard" class="btn btn-outline-secondary">
                                ← Back
                            </a>

                            <div class="d-flex gap-2">
                                <form asp-action="ApprovedMissedLog" asp-controller="Hr" method="post">
                                <input type="hidden" name="ProfileId" value="@Model.ProfileId" />
                                <input type="hidden" name="date" value="@Model.Logdate.ToString("yyyy-MM-dd")" />
                                    <button class="btn btn-success">Approve</button>
                                </form>
                                <button class="btn btn-danger">Reject</button>
                            </div>

                        </div>

                    </div>
                </div>

            </div>
        </div>

    </div>

</body>
</html>