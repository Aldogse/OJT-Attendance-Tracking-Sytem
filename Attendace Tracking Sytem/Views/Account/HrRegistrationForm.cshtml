```cshtml
@model Attendace_Tracking_Sytem.ViewModels.Account_Pages_VM.AccountRegistrationVM

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>
        HR Registration
    </title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet"
          href="~/css/Hr/hrRegistration.css">

    

</head>

<body>

    <div class="container min-vh-100 d-flex align-items-center justify-content-center">

        <div class="card register-card shadow-lg">

            <!-- HEADER -->

            <div class="register-header">

                <h2>

                    <i class="bi bi-building-fill-add"></i>

                    HR Registration

                </h2>

                <p>

                    Create your HR management account

                </p>

            </div>

            <!-- BODY -->

            <div class="card-body p-5">

                @{
                    if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div asp-validation-summary="All"
                        class="alert alert-danger">
                        </div>
                    }
                }

                <form asp-action="HrRegistrationForm"
                      method="post">

                    <!-- EMAIL -->

                    <div class="mb-4">

                        <label asp-for="Email"
                               class="form-label">

                            Email Address

                        </label>

                        <input asp-for="Email"
                               type="email"
                               required
                               class="form-control"
                               placeholder="Enter your email">

                        <span asp-validation-for="Email"
                              class="text-danger">

                        </span>

                    </div>

                    <!-- PASSWORD -->

                    <div class="mb-4">

                        <label asp-for="Password"
                               class="form-label">

                            Password

                        </label>

                        <input asp-for="Password"
                               type="password"
                               required
                               class="form-control"
                               placeholder="Enter your password">

                        <span asp-validation-for="Password"
                              class="text-danger">

                        </span>

                    </div>

                    <!-- CONFIRM PASSWORD -->

                    <div class="mb-4">

                        <label asp-for="ConfirmPassword"
                               class="form-label">

                            Confirm Password

                        </label>

                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control"
                               placeholder="Confirm your password">

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger">

                        </span>

                    </div>

                    <!-- BUTTON -->

                    <div class="d-grid">

                        <button type="submit"
                                class="btn btn-primary register-btn">

                            <i class="bi bi-check-circle-fill"></i>

                            Register HR Account

                        </button>

                    </div>

                    <!-- LOGIN -->

                    <div class="text-center mt-4 login-link">

                        <small class="text-muted">

                            Already have an account?

                            <a asp-controller="Account"
                               asp-action="LoginPage">

                                Login here

                            </a>

                        </small>

                    </div>

                </form>

            </div>

        </div>

    </div>

</body>

</html>
```
