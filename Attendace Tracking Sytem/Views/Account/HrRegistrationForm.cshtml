@model Attendace_Tracking_Sytem.ViewModels.Account_Pages_VM.AccountRegistrationVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container min-vh-100 d-flex align-items-center justify-content-center">
        <div class="card shadow rounded-4 p-4" style="width: 100%; max-width: 450px;">
            <div class="card-body">
                <h2 class="text-center mb-4"> Register Account</h2>

                <div asp-validation-summary="All"></div>

                <form asp-action="HrRegistrationForm" method="post">

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input type="email"
                               asp-for="Email"
                               placeholder="Enter your email">

                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input type="password"
                               asp-for="Password"
                               placeholder="Enter your password">
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                        <input type="password"
                               asp-for="ConfirmPassword"
                               class="form-control"
                               placeholder="Confirm your password">
                    </div>

                    <!-- Submit -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary rounded-3">
                            Register
                        </button>
                    </div>

                    <!-- Login Link -->
                    <div class="text-center mt-3">
                        <small>
                            Already have an account?
                            <a href="#">Login here</a>
                        </small>
                    </div>

                </form>
            </div>
        </div>
    </div>

</body>
</html>